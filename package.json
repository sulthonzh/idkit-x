{
  "name": "idkit-x",
  "version": "1.1.0",
  "description": "Zero-dependency ID generation library — nanoid, UUID v4/v7, ULID, Snowflake, ObjectId",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx --test tests/index.test.ts",
    "test:core": "node --import tsx --test tests/index.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["id", "uuid", "ulid", "nanoid", "snowflake", "objectid", "unique", "identifier", "zero-dependency"],
  "author": "sulthonzh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sulthonzh/idkit-x"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.0"
  }
}
